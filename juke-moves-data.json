      ],
      "coachingCues": [
        "Think 'turn sideways like you're walking through a doorway'",
        "Lead shoulder points where you want to go",
        "Tuck your arms in — don't let them stick out (that's where flags get grabbed!)",
        "Keep your speed — don't slow down to turn, turn WHILE running",
        "Head stays looking forward the whole time — watch where you're going"
      ],
      "commonMistakes": [
        "Slowing down too much to turn sideways (should be fluid, not a stop-and-turn)",
        "Arms sticking out (makes you wide again and flags are exposed)",
        "Leaning away from defender (actually makes you easier to reach)",
        "Turning the wrong way (lead with the shoulder AWAY from the defender)",
        "Not opening back up after passing (stays sideways and loses speed)"
      ]
    },
