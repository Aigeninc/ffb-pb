        {
          "phase": "acceleration",
          "description": "Rotate back to forward-facing and accelerate away",
          "steps": [
            {
              "stepNumber": 5,
              "foot": "right",
              "position": { "x": 4, "y": 70 },
              "angle": 0,
              "action": "stride",
              "weight": 0.5,
              "emphasis": false,
              "duration": 0.15,
              "teachDuration": 0.5,
              "bodyAngle": 10,
              "shoulderFake": null,
              "headDirection": "forward",
              "hipRotation": 5,
              "armPosition": "back to sprinting form",
              "forceVector": { "angle": 180, "magnitude": 0.8 }
            }
          ]
