              "hipRotation": 30,
              "armPosition": "sprinting form, driving forward",
              "forceVector": { "angle": 210, "magnitude": 0.8 }
            }
          ]
        }
      ],
      "coachingCues": [
        "Sell with your eyes — look LEFT where you're faking",
        "Plant foot at 45° angle, toes pointing away from cut direction",
        "Stay LOW through the cut — don't stand up",
        "Snap your head RIGHT when you plant — your body follows your eyes",
        "Explode out — fastest steps come AFTER the cut"
      ],
      "commonMistakes": [
        "Rounding the cut instead of sharp plant-and-push (makes it too slow)",
        "Slowing down before the fake (telegraphs the move to defender)",
        "Standing up tall during the cut (lose balance and power)",
        "Not selling the fake — just stepping without head/shoulder movement",
        "Planting with toes forward instead of angled (reduces push-off power)"
      ]
    },
    {
      "id": "drop",
      "name": "Drop",
      "description": "Dead leg / shoulder dip — a subtle half-move that shifts the defender's weight without a full juke. The 'dead leg' side goes soft while the body dips, then you accelerate past.",
      "totalSteps": 5,
      "approachDirection": "forward",
      "exitDirection": "30-degrees-left",
      "phases": [
        {
          "phase": "approach",
          "description": "Running forward, reading the defender",
          "steps": [
            {
              "stepNumber": 1,
              "foot": "right",
              "position": { "x": 4, "y": 0 },
              "angle": 0,
              "action": "stride",
              "weight": 0.5,
              "emphasis": false,
              "duration": 0.18,
              "teachDuration": 0.6,
