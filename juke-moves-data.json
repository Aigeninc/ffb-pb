          "steps": [
            {
              "stepNumber": 5,
              "foot": "right",
              "position": { "x": -10, "y": 64 },
              "angle": -15,
              "action": "stride",
              "weight": 0.5,
              "emphasis": false,
              "duration": 0.15,
              "teachDuration": 0.5,
              "bodyAngle": -20,
              "shoulderFake": null,
              "headDirection": "forward",
