{
  "metadata": {
    "version": "1.0",
    "targetAge": "8-10",
    "sport": "5v5 flag football",
    "coordinateSystem": {
      "description": "Y-axis = forward (direction of travel), X-axis = lateral (positive = player's right, negative = player's left). Units are in inches. Origin (0,0) is where the move sequence begins.",
      "yAxis": "forward",
      "xAxis": "lateral",
      "units": "inches",
      "strideRange": "18-24 inches for youth players"
    },
    "angleConventions": {
      "footAngle": "0 = toe pointing straight ahead, positive = toe rotated clockwise (right), negative = counter-clockwise (left)",
      "bodyAngle": "0 = facing forward, positive = rotated clockwise, negative = counter-clockwise",
      "forceVectorAngle": "0 = force directed forward, 90 = force directed right, 180 = force directed backward, 270 = force directed left. This is the direction force is APPLIED TO THE GROUND (reaction force moves the player opposite)."
    }
  },
  "moves": [
    {
      "id": "cut-juke",
      "name": "Cut / Juke",
      "description": "Head and shoulder fake one direction, plant outside foot hard, and cut sharply the opposite way. The classic evasion move.",
